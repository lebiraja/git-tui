/* ===================================================================
   GitPulse — Textual CSS Styles
   Dark Tokyo Night-inspired theme with premium feel.
   =================================================================== */

/* ---------- Global ---------- */
Screen {
    background: #1a1b26;
    color: #c0caf5;
}

/* ---------- Layout ---------- */
#app-grid {
    layout: horizontal;
    height: 1fr;
}

#sidebar-container {
    width: 42;
    min-width: 30;
    max-width: 55;
    background: #16161e;
    border-right: vkey #3b4261;
}

#main-panel {
    width: 1fr;
    background: #1a1b26;
}

/* ---------- Sidebar ---------- */
#sidebar-title {
    dock: top;
    width: 100%;
    height: 3;
    content-align: center middle;
    text-style: bold;
    color: #7aa2f7;
    background: #1e2030;
    border-bottom: heavy #3b4261;
    padding: 0 1;
}

/* Search input */
#search-input {
    dock: top;
    width: 100%;
    height: 3;
    margin: 0;
    padding: 0 1;
    background: #1e2030;
    color: #c0caf5;
    border-bottom: solid #3b4261;
}

#search-input:focus {
    border-bottom: solid #7aa2f7;
}

#repo-list {
    background: #16161e;
    scrollbar-color: #3b4261;
    scrollbar-color-hover: #7aa2f7;
    scrollbar-color-active: #7aa2f7;
}

/* List item styling */
RepoListItem {
    background: #16161e;
    padding: 0 0 0 1;
    margin: 0;
    border-bottom: solid #24283b;
}

RepoListItem:hover {
    background: #1f2335;
}

#repo-list:focus > RepoListItem.--highlight {
    background: #283457;
}

/* ---------- Main Panel / Tabs ---------- */
TabbedContent {
    background: #1a1b26;
    height: 1fr;
}

ContentSwitcher {
    background: #1a1b26;
    height: 1fr;
}

TabPane {
    background: #1a1b26;
    padding: 1 2;
    height: 1fr;
}

Tabs {
    background: #1e2030;
    dock: top;
    height: 3;
}

Tab {
    color: #565f89;
    background: #1e2030;
    padding: 0 2;
    margin: 0 0;
}

Tab:hover {
    color: #c0caf5;
    background: #24283b;
}

Tab.-active {
    color: #7aa2f7;
    background: #1a1b26;
    text-style: bold;
}

Underline {
    color: #7aa2f7;
}

/* ---------- DataTable (Commits, Tags) ---------- */
DataTable {
    background: #1a1b26;
    height: 1fr;
}

DataTable > .datatable--header {
    background: #1e2030;
    color: #7aa2f7;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #283457;
    color: #c0caf5;
}

DataTable > .datatable--even-row {
    background: #1a1b26;
}

DataTable > .datatable--odd-row {
    background: #1e2030;
}

/* ---------- Status / Diff / Remotes panels ---------- */
#status-summary {
    height: auto;
    background: #1a1b26;
    padding: 0 1;
}

#status-file-list {
    height: 1fr;
    background: #1a1b26;
    scrollbar-color: #3b4261;
}

#status-hints,
#commits-hints,
#branch-hints,
#diff-footer,
#remotes-hints,
#tree-hints {
    height: 1;
    dock: bottom;
    background: #1e2030;
    color: #565f89;
    padding: 0 1;
    border-top: solid #3b4261;
}

StatusFileItem {
    height: 1;
    padding: 0 1;
    background: #1a1b26;
    border-bottom: solid #1f2335;
}

StatusFileItem:hover {
    background: #1f2335;
}

#status-file-list:focus > StatusFileItem.--highlight {
    background: #283457;
}

/* ---------- Diff tab layout ---------- */
#diff-layout {
    height: 1fr;
    layout: horizontal;
}

#diff-file-panel {
    width: 30;
    min-width: 22;
    background: #16161e;
    border-right: vkey #3b4261;
}

#diff-file-header {
    height: 1;
    background: #1e2030;
    padding: 0 1;
    color: #7aa2f7;
    text-style: bold;
}

#diff-file-list {
    height: 1fr;
    background: #16161e;
    scrollbar-color: #3b4261;
}

DiffFileItem {
    height: 1;
    padding: 0 1;
    background: #16161e;
}

DiffFileItem:hover {
    background: #1f2335;
}

#diff-file-list:focus > DiffFileItem.--highlight {
    background: #283457;
}

#diff-view-panel {
    width: 1fr;
    background: #1a1b26;
    padding: 0 1;
    overflow-y: auto;
    overflow-x: auto;
}

#diff-content {
    background: #1a1b26;
    height: auto;
}

/* ---------- Remotes + Tree panels ---------- */
#remotes-scroll {
    width: 100%;
    height: 1fr;
    background: #1a1b26;
    padding: 1 1;
}

#remotes-content {
    background: #1a1b26;
    height: auto;
}

/* ---------- Commit graph ---------- */
#commits-layout {
    height: 1fr;
    layout: vertical;
}

#commits-graph-scroll {
    width: 100%;
    height: 12;
    background: #16161e;
    border: solid #3b4261;
    padding: 0 1;
    overflow-x: auto;
    overflow-y: auto;
}

#commits-graph {
    height: auto;
    background: #16161e;
}

/* ---------- Interactive file tree ---------- */
#tree-widget {
    width: 100%;
    height: 1fr;
    background: #1a1b26;
    padding: 0 1;
}

Tree > .tree--guides {
    color: #3b4261;
}

Tree > .tree--guides-hover {
    color: #7aa2f7;
}

Tree > .tree--guides-selected {
    color: #bb9af7;
}

/* ---------- Branch list ---------- */
#branch-list {
    background: #1a1b26;
    height: 1fr;
}

BranchListItem {
    height: auto;
    padding: 0 1;
    background: #1a1b26;
    border-bottom: solid #24283b;
}

BranchListItem:hover {
    background: #1f2335;
}

#branch-list:focus > BranchListItem.--highlight {
    background: #283457;
}

/* ---------- Footer ---------- */
Footer {
    background: #1e2030;
    color: #565f89;
}

Footer > .footer--key {
    color: #7aa2f7;
    text-style: bold;
    background: #24283b;
}

Footer > .footer--description {
    color: #a9b1d6;
}

/* ---------- Header ---------- */
Header {
    background: #1e2030;
    color: #7aa2f7;
    dock: top;
    height: 1;
}

HeaderTitle {
    color: #7aa2f7;
    text-style: bold;
}

/* ---------- Empty state ---------- */
.empty-message {
    color: #565f89;
    text-style: italic;
    padding: 2;
    content-align: center middle;
    width: 100%;
    height: 100%;
}

/* ---------- Scroll bars ---------- */
* {
    scrollbar-size: 1 1;
    scrollbar-color: #3b4261;
    scrollbar-color-hover: #7aa2f7;
    scrollbar-color-active: #7aa2f7;
    scrollbar-background: #1a1b26;
    scrollbar-background-hover: #1a1b26;
    scrollbar-background-active: #1a1b26;
}
